# =============================================================================
# Infrastructure Lab — environment template
# =============================================================================
# Copy to .env:  cp .env.example .env
# Then run:      make bootstrap
#
# Secret fields are intentionally BLANK below. `make bootstrap` fills them with
# strong random values. Run bootstrap BEFORE the first `make up` so the Postgres
# volume initializes with the generated password.
#
# Only `.env.example` is tracked; `.env` is gitignored. Never commit a real value.
# For production, see docs/security/secrets-management.md (SOPS / Vault) and the
# docker-compose.prod.yml overlay.
# =============================================================================

# ---- Compose project ----------------------------------------------------
# Used as the prefix for all container / network / volume names.
COMPOSE_PROJECT_NAME=infra-lab

# ---- Public edge / TLS ---------------------------------------------------
# Caddy site address. ":80" serves localhost without DNS in local dev.
# In prod, set your real domain so Caddy issues automatic TLS certificates.
PUBLIC_DOMAIN=:80
# Email used for ACME (Let's Encrypt) issuance. Required when PUBLIC_DOMAIN
# is a real hostname (ignored for ":80").
ACME_EMAIL=ops@example.com

# ---- PostgreSQL (primary datastore) -------------------------------------
POSTGRES_USER=infra
POSTGRES_PASSWORD=
POSTGRES_DB=appdb
# Host-side port for local dev tooling only. The prod overlay leaves the DB
# unpublished to the host.
POSTGRES_PORT=5432

# ---- Redis (cache / sessions) -------------------------------------------
REDIS_PASSWORD=
# Internal port (not published to the host in dev or prod). Kept here so the
# redis-exporter and backend share one source of truth. Postgres is the only
# datastore published to the host, and only in dev.
REDIS_PORT=6379

# ---- Backend API (Fastify) -----------------------------------------------
# Internal port; not published to the host. Reached over the compose network.
BACKEND_PORT=8080
# pino log level. The local override sets `debug`; the prod overlay sets `warn`.
LOG_LEVEL=info
# Build identifier surfaced in /api/status and /metrics. Dev keeps `dev`; the
# prod overlay sets this to IMAGE_TAG so a running container reports its image.
COMMIT_SHA=dev
# Hard cap (ms) for graceful drain on SIGTERM before a forced exit. The prod
# overlay raises this to 15000 to give longer-lived requests room to finish.
SHUTDOWN_TIMEOUT_MS=10000
# Rate limiting is intentionally handled at the edge (Cloudflare WAF), not
# at the origin. No RATE_LIMIT var is consumed by the stack; this comment is
# here so a reader does not expect to find it wired in the proxy.

# ---- Observability -------------------------------------------------------
# Prometheus retention window (honored via the --storage.tsdb.retention.time
# CLI flag in compose/docker-compose.yml). Scrape cadence is a literal in
# monitoring/prometheus.yml (Prometheus does not interpolate config-file envs).
PROM_RETENTION=15d

# Grafana admin credentials. BOOTSTRAPPED like the DB password.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ---- Backups & retention -------------------------------------------------
# How many daily pg_dump snapshots to keep in ./backups.
BACKUP_RETENTION_DAYS=7

# ---- Production overlay (docker-compose.prod.yml) ------------------------
# Ignored by the dev stack; read only by the prod overlay.
REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest
BACKEND_REPLICAS=2
# Resource caps set via deploy.resources in the prod overlay.
BACKEND_MEMORY_LIMIT=512m
BACKEND_CPU_LIMIT=0.50

# ---- Notes ---------------------------------------------------------------
# * Secrets (POSTGRES_PASSWORD, REDIS_PASSWORD, GRAFANA_ADMIN_PASSWORD) are
#   blank by design; `make bootstrap` regenerates them.
# * Order matters: bootstrap before the first up.
# * Prod: prefer SOPS / a secrets manager over plaintext .env.
